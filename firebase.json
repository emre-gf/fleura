{
  "hosting": {
    "site": "fleuranails",
    "public": ".",
    "redirects": [
      {
        "source": "/index.html",
        "destination": "/",
        "type": 301
      },
      {
        "source": "/blog",
        "destination": "/blog.html",
        "type": 301
      },
      {
        "source": "/iletisim",
        "destination": "/iletisim.html",
        "type": 301
      },
      {
        "source": "/izmir-protez-tirnak",
        "destination": "/izmir-protez-tirnak.html",
        "type": 301
      },
      {
        "source": "/balcovada-tirnak",
        "destination": "/balcovada-tirnak.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/balcova-protez-tirnak",
        "destination": "/balcova-protez-tirnak/index.html"
      },
      {
        "source": "/izmir-kalici-oje",
        "destination": "/izmir-kalici-oje/index.html"
      },
      {
        "source": "/karsiyaka-protez-tirnak",
        "destination": "/karsiyaka-protez-tirnak/index.html"
      },
      {
        "source": "/bornova-kalici-oje",
        "destination": "/bornova-kalici-oje/index.html"
      },
      {
        "source": "/alsancak-nail-art",
        "destination": "/alsancak-nail-art/index.html"
      },
      {
        "source": "/narlidere-tirnak",
        "destination": "/narlidere-tirnak/index.html"
      },
      {
        "source": "/guzelbahce-kalici-oje",
        "destination": "/guzelbahce-kalici-oje/index.html"
      },
      {
        "source": "/cigli-protez-tirnak",
        "destination": "/cigli-protez-tirnak/index.html"
      },
      {
        "source": "/buca-tirnak",
        "destination": "/buca-tirnak/index.html"
      },
      {
        "source": "/bayrakli-kalici-oje",
        "destination": "/bayrakli-kalici-oje/index.html"
      },
      {
        "source": "/karabaglar-tirnak",
        "destination": "/karabaglar-tirnak/index.html"
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md"
    ],
    "errorDocument": "404.html",
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-XSS-Protection",
            "value": "1; mode=block"
          }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|avif|ico|woff|woff2|ttf|eot)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.@(mp4|webm|ogg|gif)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          }
        ]
      }
    ]
  }
}
